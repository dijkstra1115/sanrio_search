LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
APP_BASE_URL=https://your-service.zeabur.app
LOG_LEVEL=INFO
LOOKUP_TIMEOUT_SECONDS=45
PLAYWRIGHT_HEADLESS=false
PLAYWRIGHT_FALLBACK_TO_HEADED=false
# Docker/Zeabur headed deployments can set:
# PLAYWRIGHT_CLI_COMMAND=playwright-cli
# Leave this unset for direct Linux/WSL uvicorn runs without a long-lived DISPLAY.
